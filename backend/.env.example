# Claude API klíč pro extrakci dokladů
ANTHROPIC_API_KEY=sk-ant-...

# Model pro extrakci (sonnet = poměr cena/přesnost, opus = nejvyšší přesnost, haiku = nejlevnější)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Port backendu
PORT=3000

# Účetní období: "mesic" nebo "ctvrtleti"
DEFAULT_PERIOD_TYPE=ctvrtleti

# --- Odesílání e-mailem (volitelné) ---
# Pokud nevyplníš, "Odeslat" jen vygeneruje PDF + CSV a vrátí odkazy.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ACCOUNTANT_EMAIL=
