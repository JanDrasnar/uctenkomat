# Claude API klíč pro extrakci dokladů
ANTHROPIC_API_KEY=sk-ant-...

# Model pro extrakci (sonnet = poměr cena/přesnost, opus = nejvyšší přesnost, haiku = nejlevnější)
ANTHROPIC_MODEL=claude-sonnet-4-6

# Port backendu
PORT=3000

# Účetní období: "mesic" nebo "ctvrtleti"
DEFAULT_PERIOD_TYPE=ctvrtleti

# --- Úložiště ---
# Bez DATABASE_URL běží JSON úložiště (data/db.json) — zero-config pro vývoj.
# S DATABASE_URL se použije Postgres (schéma se vytvoří idempotentně při startu).
DATABASE_URL=
# Pro Railway/managed Postgres nech SSL zapnuté; pro lokální Postgres dej "false".
DATABASE_SSL=true

# --- Odesílání e-mailem ---
# Stejná provider-fallback logika a názvy proměnných jako propadmin.cz:
# Resend → SendGrid → Gmail SMTP → obecné SMTP. Stačí nasdílet stejné hodnoty
# jako v propadmin (Railway). Pokud nic nevyplníš, "Odeslat" jen vygeneruje
# PDF + CSV a vrátí odkazy ke stažení.

# Kam se balík posílá (e-mail účetní)
ACCOUNTANT_EMAIL=

# Odesílatel (doména musí být ověřená u providera — lze sdílet s propadmin)
EMAIL_FROM=noreply@propadmin.cz
EMAIL_FROM_NAME=Účtenkomat

# 1) Resend (doporučeno)
RESEND_API_KEY=
# 2) SendGrid
SENDGRID_API_KEY=
# 3) Gmail SMTP
GMAIL_USER=
GMAIL_APP_PASSWORD=
# 4) Obecné SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
